            </size>
           </property>
          </spacer>
         </item>
        </layout>
       </item>
       <item>
        <layout class="QGridLayout" name="gridLayoutParams">
         <item row="0" column="0">
          <widget class="QCheckBox" name="chkLzma">
           <property name="text">
            <string>LZMA算法 (--lzma)</string>
