      </layout>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="groupBoxVersion">
      <property name="title">
       <string>选择UPX版本</string>
      </property>
      <layout class="QHBoxLayout" name="horizontalLayoutVersion">
       <item>
        <widget class="QComboBox" name="cmbUpxVersion">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
           <horstretch>0</horstretch>
           <verstretch>0</verstretch>
          </sizepolicy>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="groupBoxAction">
      <property name="title">
       <string>操作类型</string>
      </property>
      <layout class="QHBoxLayout" name="horizontalLayoutAction">
       <item>
        <widget class="QRadioButton" name="rdoCompress">
         <property name="text">
          <string>压缩</string>
         </property>
         <property name="checked">
          <bool>true</bool>
