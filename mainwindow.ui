        </widget>
       </item>
       <item>
        <widget class="QRadioButton" name="rdoDecompress">
         <property name="text">
          <string>解压</string>
         </property>
        </widget>
       </item>
       <item>
        <spacer name="horizontalSpacer">
         <property name="orientation">
